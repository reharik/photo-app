{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    "**/dist/**",
    "**/build/**",
    "**/coverage/**",
    "**/.nx/**",
    "**/node_modules/**"
  ],
  "workspaces": {
    ".": {
      "entry": [
        "scripts/**/*.{js,ts,mjs}",
        "*.config.{js,ts,mjs,cjs}",
        "nx.json"
      ],
      "project": [
        "scripts/**/*.{js,ts,mjs}",
        "*.config.{js,ts,mjs,cjs}"
      ]
    },

    "apps/api": {
      "entry": [
        "src/index.ts",
        "src/server.ts",
        "src/main.ts",
        "src/**/*.graphql",
        "src/**/di/generated/ioc-manifest.{ts,js,mjs}",
        "codegen.{ts,js,mjs,cjs}",
        "project.json"
      ],
      "project": [
        "src/**/*.{ts,tsx,js,mjs,cjs,graphql}",
        "*.config.{ts,js,mjs,cjs}",
        "project.json",
        "package.json"
      ]
    },

    "apps/web": {
      "entry": [
        "src/main.tsx",
        "src/main.ts",
        "src/App.tsx",
        "src/**/di/generated/ioc-manifest.{ts,js,mjs}",
        "vite.config.{ts,js,mjs,cjs}",
        "project.json"
      ],
      "project": [
        "src/**/*.{ts,tsx,js,mjs,cjs,css,scss}",
        "index.html",
        "*.config.{ts,js,mjs,cjs}",
        "project.json",
        "package.json"
      ]
    },

    "apps/media-worker": {
      "entry": [
        "src/index.ts",
        "src/main.ts",
        "src/worker.ts",
        "src/runMediaWorkerLoop.ts",
        "src/**/di/generated/ioc-manifest.{ts,js,mjs}",
        "project.json"
      ],
      "project": [
        "src/**/*.{ts,tsx,js,mjs,cjs}",
        "*.config.{ts,js,mjs,cjs}",
        "project.json",
        "package.json"
      ]
    },

    "packages/foundation/contracts": {
      "entry": [
        "src/index.ts"
      ],
      "project": [
        "src/**/*.{ts,tsx,js,mjs,cjs}",
        "*.config.{ts,js,mjs,cjs}",
        "package.json"
      ]
    },

    "packages/context/media-core": {
      "entry": [
        "src/index.ts",
        "src/**/di/generated/ioc-manifest.{ts,js,mjs}"
      ],
      "project": [
        "src/**/*.{ts,tsx,js,mjs,cjs}",
        "*.config.{ts,js,mjs,cjs}",
        "package.json"
      ]
    }
  }
}