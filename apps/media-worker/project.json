{
  "name": "media-worker",
  "projectType": "application",
  "sourceRoot": "{projectRoot}/src",
  "targets": {
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx rimraf dist",
        "cwd": "{projectRoot}"
      }
    },
    "gen:container": {
      "executor": "nx:run-commands",
      "dependsOn": ["media-core:barrels", "contracts:barrels"],
      "options": {
        "command": "ioc generate",
        "cwd": "{projectRoot}"
      }
    },
    "prepare": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run media-worker:clean",
          "nx run-many -t build -p contracts infrastructure media-core --parallel=3",
          "nx run media-worker:gen:container"
        ],
        "parallel": false,
        "cwd": "{workspaceRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["prepare"],
      "options": {
        "command": "vite build --config vite.config.mjs",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "development": {
          "command": "vite build --config vite.config.mjs --mode development"
        },
        "production": {
          "command": "vite build --config vite.config.mjs --mode production"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["{projectRoot}/**/*.{ts,tsx,js,mjs,cjs}"],
        "forceColor": true,
        "fix": false
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --runInBand --passWithNoTests",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "runInBand": {
          "command": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --runInBand --detectOpenHandles --passWithNoTests"
        }
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write {projectRoot}/src/**/*.{ts,tsx,js,jsx,json}"
      }
    }
  },
  "tags": ["type:app"]
}
