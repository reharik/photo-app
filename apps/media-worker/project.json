{
  "name": "media-worker",
  "projectType": "application",
  "sourceRoot": "{projectRoot}/src",
  "targets": {
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx rimraf dist",
        "cwd": "{projectRoot}"
      }
    },
    "gen-ioc": {
      "executor": "nx:run-commands",
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "{projectRoot}/src/ioc.config.ts",
        "{projectRoot}/src/**/*.ts",
        "!{projectRoot}/src/**/*.spec.ts",
        "!{projectRoot}/src/**/*.test.ts",
        "!{projectRoot}/src/**/*.tests.ts",
        "!{projectRoot}/src/**/tests/**",
        "!{projectRoot}/src/generated/**",
        {
          "dependentTasksOutputFiles": "**/ioc-manifest.ts",
          "transitive": true
        }
      ],
      "outputs": [
        "{projectRoot}/src/generated/ioc-composed.ts",
        "{projectRoot}/src/generated/ioc-manifest.ts",
        "{projectRoot}/src/generated/ioc-registry.types.ts"
      ],
      "options": {
        "command": "ioc generate",
        "cwd": "{projectRoot}"
      }
    },
    "build:vite": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["prod", "^prod", "{projectRoot}/vite.config.mjs"],
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["gen-ioc", "heic-converter:build", "^build"],
      "options": {
        "command": "vite build --config vite.config.mjs",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "development": {
          "command": "vite build --config vite.config.mjs --mode development"
        },
        "production": {
          "command": "vite build --config vite.config.mjs --mode production"
        }
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["build:vite"],
      "options": {
        "command": "echo 'media-worker build complete'",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build", "gen-ioc"],
      "options": {
        "command": "tsc --noEmit -p tsconfig.json",
        "cwd": "{projectRoot}"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nodemon",
        "cwd": "{projectRoot}"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["{projectRoot}/**/*.{ts,tsx,js,mjs,cjs}"],
        "forceColor": true,
        "fix": false
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --runInBand --passWithNoTests && node --import tsx --experimental-test-isolation=process --experimental-test-module-mocks --test src/infrastructure/exif/computeCaptureInstant.test.ts src/infrastructure/exif/extractCaptureTime.fieldPreference.test.ts src/infrastructure/exif/extractCaptureTime.test.ts",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "runInBand": {
          "command": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --runInBand --detectOpenHandles --passWithNoTests"
        }
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write {projectRoot}/src/**/*.{ts,tsx,js,jsx,json}"
      }
    }
  },
  "tags": ["type:app", "scope:apps"]
}
