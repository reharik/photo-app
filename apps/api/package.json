{
  "name": "@app/api",
  "private": true,
  "description": "BetanaMe API",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "nx build api",
    "build:dev": "nx build api --configuration=development",
    "build:prod": "nx build api --configuration=production",
    "clean": "nx clean api",
    "db:baseline:migrations": "tsx src/localScripts/baselineKnexMigrations.ts",
    "db:make": "nx run api:db:make",
    "db:migrate:local": "nx run api:db:migrate",
    "db:migrate:prod": "knex --knexfile dist/knexfile.js migrate:latest",
    "db:seed:local": "nx run api:db:seed",
    "dev": "nx dev api",
    "gen:gql": "nx gen-gql api",
    "gen:ioc": "nx gen-ioc api",
    "ioc:bundles": "ioc bundles",
    "ioc:discover": "ioc inspect --discovery",
    "ioc:inspect": "ioc inspect",
    "lint": "nx lint api",
    "seed:dev-admin": "tsx src/localScripts/seedDevAdmin.ts",
    "seed:dev-admin:clean": "tsx src/localScripts/cleanDevAdmin.ts",
    "serve": "nx serve api",
    "start": "node dist/index.js",
    "start:dev": "node --enable-source-maps dist/index.js",
    "test": "nx test api",
    "test-integration": "nx run api:test-integration",
    "typecheck": "nx typecheck api"
  },
  "dependencies": {
