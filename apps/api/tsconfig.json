{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "noEmit": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {},
    "types": ["jest", "vite/client"],
    "plugins": [
      {
        "transform": "typia/lib/transform"
      }
    ],
    "skipLibCheck": true,
    "strictNullChecks": true,
    "strict": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "include": [
    "src/**/*.ts",
    "db/**/*.ts",
    "../../packages/context/notifications/src/**/*.tsx"
  ],
  "exclude": [
    "jest.*",
    "dist",
    "node_modules",
    "src/_original/**",
    "../../**/dist/**" // <-- catches packages/*/dist anywhere up the tree
  ]
}
