{
  "name": "api",
  "projectType": "application",
  "sourceRoot": "{projectRoot}/src",
  "targets": {
    "ts-patch:install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -e \"try { require('child_process').execSync('ts-patch install', {stdio: 'ignore'}); } catch(e) {}\""
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx rimraf dist",
        "cwd": "{projectRoot}"
      }
    },
    "build:knexfile": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist/db"],
      "options": {
        "commands": ["mkdir -p dist/db", "npx tsc -p tsconfig.db.json"],
        "parallel": false,
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["prepare"],
      "options": {
        "command": "vite build --config vite.config.mjs && mkdir -p dist/graphql && cp -R src/graphql/schema dist/graphql/ && mkdir -p dist/db && npx tsc -p tsconfig.db.json",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "development": {
          "command": "vite build --config vite.config.mjs --mode development && mkdir -p dist/graphql && cp -R src/graphql/schema dist/graphql/ && mkdir -p dist/db && npx tsc -p tsconfig.db.json"
        },
        "production": {
          "command": "vite build --config vite.config.mjs --mode production && mkdir -p dist/graphql && cp -R src/graphql/schema dist/graphql/ && mkdir -p dist/db && npx tsc -p tsconfig.db.json"
        }
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "api:build:development",
        "watch": true
      }
    },
    "serve:with-contracts": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["npm run dev --workspace=@packages/contracts", "nx run api:serve"],
        "parallel": true
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx eslint --config {projectRoot}/eslint.config.js \"{projectRoot}/**/*.{ts,tsx,js,mjs,cjs}\"",
          "npx eslint --config {projectRoot}/eslint.test.config.js --quiet --no-error-on-unmatched-pattern \"{projectRoot}/**/*.tests.ts\" \"{projectRoot}/**/*.tests.tsx\" \"{projectRoot}/**/*.test.ts\" \"{projectRoot}/**/*.test.tsx\" \"{projectRoot}/**/*.spec.ts\" \"{projectRoot}/**/*.spec.tsx\" \"{projectRoot}/src/tests/**/*.ts\" \"{projectRoot}/src/tests/**/*.tsx\""
        ],
        "parallel": false
      },
      "configurations": {
        "fix": {
          "commands": [
            "npx eslint --config {projectRoot}/eslint.config.js --fix \"{projectRoot}/**/*.{ts,tsx,js,mjs,cjs}\"",
            "npx eslint --config {projectRoot}/eslint.test.config.js --quiet --fix --no-error-on-unmatched-pattern \"{projectRoot}/**/*.tests.ts\" \"{projectRoot}/**/*.tests.tsx\" \"{projectRoot}/**/*.test.ts\" \"{projectRoot}/**/*.test.tsx\" \"{projectRoot}/**/*.spec.ts\" \"{projectRoot}/**/*.spec.tsx\" \"{projectRoot}/src/tests/**/*.ts\" \"{projectRoot}/src/tests/**/*.tsx\""
          ],
          "parallel": false
        }
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --runInBand --passWithNoTests",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "runInBand": {
          "command": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --runInBand --detectOpenHandles --passWithNoTests"
        }
      }
    },
    "test-integration": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.integration.config.js --runInBand --passWithNoTests",
        "cwd": "{projectRoot}"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write {projectRoot}/src/**/*.{ts,tsx,js,jsx,json}"
      }
    },
    "gen:graphql": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["graphql-codegen", "nx run contracts:gen:graphql:enums"],
        "parallel": false,
        "cwd": "{projectRoot}"
      }
    },
    "gen:container": {
      "executor": "nx:run-commands",
      "dependsOn": ["media-core:barrels", "gen:graphql"],
      "options": {
        "command": "ioc generate",
        "cwd": "{projectRoot}"
      }
    },
    "prepare": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run api:ts-patch:install",
          "nx run api:clean",
          "nx run-many -t build -p contracts infrastructure media-core --parallel=3",
          "nx run api:gen:container"
        ],
        "parallel": false,
        "cwd": "{workspaceRoot}"
      }
    }
  },

  "tags": ["type:app"]
}
