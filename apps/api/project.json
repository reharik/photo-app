{
  "name": "api",
  "projectType": "application",
  "sourceRoot": "{projectRoot}/src",
  "targets": {
    "ts-patch:install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -e \"try { require('child_process').execSync('ts-patch install', {stdio: 'ignore'}); } catch(e) {}\""
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx rimraf dist",
        "cwd": "{projectRoot}"
      }
    },
    "gen-gql": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["{projectRoot}/src/graphql/schema/**/*.graphql", "{projectRoot}/codegen.yml"],
      "outputs": [
        "{projectRoot}/src/graphql/generated/schema.graphql",
        "{projectRoot}/src/graphql/generated/types.generated.ts"
      ],
      "options": {
        "cwd": "{projectRoot}",
        "commands": [
          "graphql-codegen --config codegen.yml",
          "npx prettier --write src/graphql/generated/schema.graphql src/graphql/generated/types.generated.ts"
        ],
        "parallel": false
      }
    },
    "gen-ioc": {
      "executor": "nx:run-commands",
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "{projectRoot}/src/ioc.config.ts",
        "{projectRoot}/src/**/*.ts",
        "!{projectRoot}/src/**/*.spec.ts",
        "!{projectRoot}/src/**/*.test.ts",
        "!{projectRoot}/src/**/*.tests.ts",
        "!{projectRoot}/src/**/tests/**",
        "!{projectRoot}/src/di/generated/**",
        {
          "dependentTasksOutputFiles": "**/ioc-manifest.ts",
          "transitive": true
        }
      ],
      "outputs": [
        "{projectRoot}/src/di/generated/ioc-composed.ts",
        "{projectRoot}/src/di/generated/ioc-manifest.ts",
        "{projectRoot}/src/di/generated/ioc-registry.types.ts"
      ],
      "options": {
        "command": "ioc generate",
        "cwd": "{projectRoot}"
      }
    },
    "build:vite": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["prod", "^prod", "{projectRoot}/vite.config.mjs"],
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["gen-ioc", "^build"],
      "options": {
        "command": "vite build --config vite.config.mjs",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "development": {
          "command": "vite build --config vite.config.mjs --mode development"
        },
        "production": {
          "command": "vite build --config vite.config.mjs --mode production"
        }
      }
    },
    "build:graphql-static": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["{projectRoot}/src/graphql/schema/**"],
      "outputs": ["{projectRoot}/dist/graphql"],
      "dependsOn": ["build:vite"],
      "options": {
        "command": "mkdir -p dist/graphql && cp -R src/graphql/schema dist/graphql/",
        "cwd": "{projectRoot}"
      }
    },
    "build:db": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{projectRoot}/tsconfig.db.json",
        "{projectRoot}/db/**/*.ts"
      ],
      "dependsOn": ["build:vite"],
      "outputs": ["{projectRoot}/dist/db"],
      "options": {
        "commands": ["mkdir -p dist/db", "npx tsc -p tsconfig.db.json"],
        "parallel": false,
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["build:vite", "build:graphql-static", "build:db"],
      "options": {
        "command": "echo 'api build complete'",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build", "gen-gql"],
      "options": {
        "command": "tsc --noEmit -p tsconfig.json",
        "cwd": "{projectRoot}"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nodemon",
        "cwd": "{projectRoot}"
      }
    },
    "serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "api:build:development",
        "watch": true
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx eslint --config {projectRoot}/eslint.config.js \"{projectRoot}/**/*.{ts,tsx,js,mjs,cjs}\"",
          "npx eslint --config {projectRoot}/eslint.test.config.js --quiet --no-error-on-unmatched-pattern \"{projectRoot}/**/*.tests.ts\" \"{projectRoot}/**/*.tests.tsx\" \"{projectRoot}/**/*.test.ts\" \"{projectRoot}/**/*.test.tsx\" \"{projectRoot}/**/*.spec.ts\" \"{projectRoot}/**/*.spec.tsx\" \"{projectRoot}/src/tests/**/*.ts\" \"{projectRoot}/src/tests/**/*.tsx\""
        ],
        "parallel": false
      },
      "configurations": {
        "fix": {
          "commands": [
            "npx eslint --config {projectRoot}/eslint.config.js --fix \"{projectRoot}/**/*.{ts,tsx,js,mjs,cjs}\"",
            "npx eslint --config {projectRoot}/eslint.test.config.js --quiet --fix --no-error-on-unmatched-pattern \"{projectRoot}/**/*.tests.ts\" \"{projectRoot}/**/*.tests.tsx\" \"{projectRoot}/**/*.test.ts\" \"{projectRoot}/**/*.test.tsx\" \"{projectRoot}/**/*.spec.ts\" \"{projectRoot}/**/*.spec.tsx\" \"{projectRoot}/src/tests/**/*.ts\" \"{projectRoot}/src/tests/**/*.tsx\""
          ],
          "parallel": false
        }
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --runInBand --passWithNoTests",
        "cwd": "{projectRoot}"
      },
      "configurations": {
        "runInBand": {
          "command": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --runInBand --detectOpenHandles --passWithNoTests"
        }
      }
    },
    "test-integration": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.integration.config.js --runInBand --passWithNoTests",
        "cwd": "{projectRoot}"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write {projectRoot}/src/**/*.{ts,tsx,js,jsx,json}"
      }
    },
    "db:migrate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "NODE_OPTIONS=--import=tsx npx knex --knexfile src/knexfile.ts migrate:latest",
        "cwd": "{projectRoot}"
      }
    },
    "db:seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "NODE_OPTIONS=--import=tsx npx knex --knexfile src/knexfile.ts seed:run",
        "cwd": "{projectRoot}"
      }
    },
    "db:make": {
      "executor": "nx:run-commands",
      "options": {
        "command": "NODE_OPTIONS=--import=tsx npx knex --knexfile src/knexfile.ts migrate:make",
        "cwd": "{projectRoot}"
      }
    }
  },
  "tags": ["type:app", "scope:apps"]
}
