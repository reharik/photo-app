{
  "name": "web",
  "projectType": "application",
  "sourceRoot": "{projectRoot}/src",
  "targets": {
    "ts-patch:install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node -e \"try { require('child_process').execSync('ts-patch install', {stdio: 'ignore'}); } catch(e) {}\""
      }
    },
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["npx rimraf dist", "npx rimraf src/graphql/generated"],
        "parallel": false,
        "cwd": "{projectRoot}"
      }
    },
    "sync-schema": {
      "executor": "nx:run-commands",
      "dependsOn": ["api:schema-gen"],
      "outputs": ["{projectRoot}/src/graphql/generated/schema.graphql"],
      "options": {
        "commands": [
          "test -f ../api/src/graphql/generated/schema.graphql || (echo 'ERROR: Schema file not found at apps/api/src/graphql/generated/schema.graphql. Run npm run schema-gen:api first.' && exit 1)",
          "mkdir -p src/graphql/generated",
          "cp ../api/src/graphql/generated/schema.graphql src/graphql/generated/schema.graphql"
        ],
        "parallel": false,
        "cwd": "{projectRoot}"
      }
    },
    "codegen": {
      "executor": "nx:run-commands",
      "dependsOn": ["sync-schema", "contracts:build"],
      "inputs": [
        "{projectRoot}/codegen.yml",
        "{projectRoot}/src/graphql/**/*.graphql",
        "{projectRoot}/src/graphql/generated/schema.graphql"
      ],
      "outputs": [
        "{projectRoot}/src/graphql/generated/types.ts",
        "{projectRoot}/src/graphql/generated/graphql-smart-enum-type-policies.ts"
      ],
      "options": {
        "commands": [
          "graphql-codegen --config codegen.yml",
          "npx prettier --write src/graphql/generated/types.ts src/graphql/generated/graphql-smart-enum-type-policies.ts"
        ],
        "parallel": false,
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["ts-patch:install", "codegen"],
      "options": {
        "outputPath": "apps/web/dist",
        "configFile": "{projectRoot}/vite.config.js",
        "tsConfig": "{projectRoot}/tsconfig.json",
        "mode": "production"
      }
    },
    "dev": {
      "executor": "@nx/vite:dev-server",
      "dependsOn": ["codegen"],
      "options": {
        "buildTarget": "web:build",
        "port": 5173
      }
    },
    "preview": {
      "executor": "@nx/vite:preview-server",
      "options": {
        "buildTarget": "web:build",
        "port": 4173
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["contracts:build", "codegen"],
      "options": {
        "command": "tsc --noEmit -p tsconfig.json",
        "cwd": "{projectRoot}"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx eslint --config {projectRoot}/eslint.config.js \"{projectRoot}/**/*.{ts,tsx,js,jsx}\"",
          "npx eslint --config {projectRoot}/eslint.test.config.js --quiet --no-error-on-unmatched-pattern \"{projectRoot}/**/*.tests.ts\" \"{projectRoot}/**/*.tests.tsx\" \"{projectRoot}/**/*.test.ts\" \"{projectRoot}/**/*.test.tsx\" \"{projectRoot}/**/*.spec.ts\" \"{projectRoot}/**/*.spec.tsx\" \"{projectRoot}/src/tests/**/*.ts\" \"{projectRoot}/src/tests/**/*.tsx\""
        ],
        "parallel": false
      },
      "configurations": {
        "fix": {
          "commands": [
            "npx eslint --config {projectRoot}/eslint.config.js --fix \"{projectRoot}/**/*.{ts,tsx,js,jsx}\"",
            "npx eslint --config {projectRoot}/eslint.test.config.js --quiet --fix --no-error-on-unmatched-pattern \"{projectRoot}/**/*.tests.ts\" \"{projectRoot}/**/*.tests.tsx\" \"{projectRoot}/**/*.test.ts\" \"{projectRoot}/**/*.test.tsx\" \"{projectRoot}/**/*.spec.ts\" \"{projectRoot}/**/*.spec.tsx\" \"{projectRoot}/src/tests/**/*.ts\" \"{projectRoot}/src/tests/**/*.tsx\""
          ],
          "parallel": false
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "{projectRoot}/jest.config.js",
        "passWithNoTests": true
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write {projectRoot}/src/**/*.{ts,tsx,js,jsx,json}"
      }
    }
  },
  "tags": ["type:app", "scope:apps"]
}
