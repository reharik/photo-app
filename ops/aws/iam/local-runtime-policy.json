{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadDeployBucketList",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::network-deploy-709865789463-us-east-1"
    },
    {
      "Sid": "ReadDeployBucketObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::network-deploy-709865789463-us-east-1/*"
    },
    {
      "Sid": "AppBucketList",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::photoshare-dev-media-709865789463-use1"
    },
    {
      "Sid": "AppBucketObjects",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject"
      ],
      "Resource": "arn:aws:s3:::photoshare-dev-media-709865789463-use1/*"
    }
  ]
}
