# CI e2e — root compose interpolation vars. DUMMY VALUES ONLY (committed).
# Copied to ./.env by the e2e workflow so `docker compose` can interpolate
# ${APP_NAME} etc. Real S3 credentials are injected per-container from GitHub
# OIDC (see infra/config/docker-compose/ci.yml), NOT from this file.
APP_NAME=homeroll
COMPOSE_PROJECT_NAME=homeroll-ci
