{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    // Test-runner: no emit; Playwright needs DOM lib and bundler resolution (see §2.1 Monorepo.md).
    "baseUrl": ".",
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "isolatedModules": true,
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "types": ["node", "@playwright/test"]
  },
  "include": [
    "fixtures/**/*.ts",
    "tests/**/*.ts",
    "routines/**/*.ts",
    "reporters/**/*.ts",
    "global-setup.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "test-results", "playwright-report", "playwright/.cache"]
}
