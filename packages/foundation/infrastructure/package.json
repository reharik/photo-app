  "dependencies": {
    "ioc-manifest": "^1.4.1",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.2"
