{
  "name": "contracts",
  "projectType": "library",
  "sourceRoot": "{projectRoot}/src",
  "targets": {
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "npx rimraf dist"
      }
    },
    "barrels": {
      "executor": "nx:run-commands",
      "cache": true,
      "dependsOn": ["gen-enums"],
      "inputs": [
        "{projectRoot}/barrelsby.json",
        "{projectRoot}/src/enums/**/*.ts",
        "!{projectRoot}/src/enums/index.ts",
        "{projectRoot}/src/types/**/*.ts",
        "!{projectRoot}/src/types/index.ts",
        { "dependentTasksOutputFiles": "**/graphqlSmartEnums.ts" }
      ],
      "outputs": [
        "{projectRoot}/src/enums/index.ts",
        "{projectRoot}/src/types/index.ts"
      ],
      "options": {
        "cwd": "{projectRoot}",
        "command": "npx barrelsby --config barrelsby.json"
      }
    },
    "gen-enums": {
      "executor": "nx:run-commands",
      "cache": true,
      "dependsOn": ["api:gen-gql"],
      "inputs": [
        "{projectRoot}/codegen.yml",
        "{workspaceRoot}/apps/api/src/graphql/generated/schema.graphql",
        { "dependentTasksOutputFiles": "**/schema.graphql" }
      ],
      "outputs": ["{projectRoot}/src/enums/graphqlSmartEnums.ts"],
      "options": {
        "cwd": "{projectRoot}",
        "commands": [
          "test -f ../../../apps/api/src/graphql/generated/schema.graphql || (echo \"Schema file not found at apps/api/src/graphql/generated/schema.graphql. Run 'npm run gen:gql:api' first, or ensure contracts:gen-enums depends on api:gen-gql in project.json (it does, but nx may have silently skipped it).\" && exit 1)",
          "graphql-codegen --config codegen.yml",
          "npx prettier --write src/enums/graphqlSmartEnums.ts"
        ],
        "parallel": false
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "dependsOn": ["barrels", "gen-enums", "^build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "outputPath": "{projectRoot}/dist",
        "tsConfig": "{projectRoot}/tsconfig.json",
        "main": "{projectRoot}/src/index.ts"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "tsc -w -p tsconfig.json"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx eslint --config {projectRoot}/eslint.config.js \"{projectRoot}/**/*.{ts,tsx,js,jsx}\"",
          "npx eslint --config {projectRoot}/eslint.test.config.js --quiet --no-error-on-unmatched-pattern \"{projectRoot}/**/*.tests.ts\" \"{projectRoot}/**/*.tests.tsx\" \"{projectRoot}/**/*.test.ts\" \"{projectRoot}/**/*.test.tsx\" \"{projectRoot}/**/*.spec.ts\" \"{projectRoot}/**/*.spec.tsx\" \"{projectRoot}/src/tests/**/*.ts\" \"{projectRoot}/src/tests/**/*.tsx\""
        ],
        "parallel": false
      },
      "configurations": {
        "fix": {
          "commands": [
            "npx eslint --config {projectRoot}/eslint.config.js --fix \"{projectRoot}/**/*.{ts,tsx,js,jsx}\"",
            "npx eslint --config {projectRoot}/eslint.test.config.js --quiet --fix --no-error-on-unmatched-pattern \"{projectRoot}/**/*.tests.ts\" \"{projectRoot}/**/*.tests.tsx\" \"{projectRoot}/**/*.test.ts\" \"{projectRoot}/**/*.test.tsx\" \"{projectRoot}/**/*.spec.ts\" \"{projectRoot}/**/*.spec.tsx\" \"{projectRoot}/src/tests/**/*.ts\" \"{projectRoot}/src/tests/**/*.tsx\""
          ],
          "parallel": false
        }
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "{projectRoot}/jest.config.js",
        "passWithNoTests": true
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write {projectRoot}/src/**/*.{ts,tsx,js,jsx,json}"
      }
    }
  },
  "tags": ["layer:foundation", "scope:shared", "scope:packages"]
}
