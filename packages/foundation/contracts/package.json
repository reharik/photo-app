{
  "name": "@packages/contracts",
  "version": "0.1.0",
  "dependencies": {
    "@reharik/smart-enum": "^0.4.0",
    "typia": "^9.7.2"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^6.2.1",
    "@reharik/graphql-codegen-smart-enum": "^0.3.7",
    "@reharik/graphql-codegen-smart-enum-preset": "^0.1.1",
    "@types/node": "^24.9.1",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "graphql": "^16.13.1",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.2"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "main": "./dist/src/index.js",
  "private": true,
  "scripts": {
    "build": "rimraf dist && nx build contracts",
    "dev": "tsc -w -p tsconfig.json",
    "gen:graphql:enums": "graphql-codegen --config codegen.yml && npx prettier --write src/enums/graphqlSmartEnums.ts"
  },
  "type": "module",
  "types": "./dist/src/index.d.ts"
}
