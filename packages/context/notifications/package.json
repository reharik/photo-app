{
  "name": "@packages/notifications",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./iocManifest": {
      "development": "./src/generated/ioc-manifest.ts",
      "types": "./dist/src/generated/ioc-manifest.d.ts",
      "default": "./dist/src/generated/ioc-manifest.js"
    },
    "./iocTypes": {
      "development": "./src/generated/ioc-registry.types.ts",
      "types": "./dist/src/generated/ioc-registry.types.d.ts",
      "default": "./dist/src/generated/ioc-registry.types.js"
    }
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "barrels": "nx barrels notifications",
    "build": "nx build notifications",
    "dev": "nx dev notifications",
    "gen:ioc": "nx gen-ioc notifications",
    "ioc:discover": "ioc inspect --discovery",
    "ioc:inspect": "ioc inspect",
    "ioc:validate": "ioc validate",
    "lint": "nx lint notifications",
    "test": "NODE_OPTIONS='--experimental-vm-modules' nx test notifications",
    "test:localstack": "NODE_OPTIONS='--experimental-vm-modules' AWS_ENDPOINT=http://localhost:4566 nx test notifications --testPathPattern=emailLocalstack"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1069.0",
    "@packages/contracts": "*",
    "@packages/infrastructure": "*",
    "@react-email/components": "^1.0.12",
    "ioc-manifest": "^1.5.0",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/node": "^24.9.1",
    "@types/react": "^19.0.10",
    "typescript": "^5.9.2"
  }
}
