{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "types": ["jest", "node"],
    "baseUrl": ".",
    "paths": {
      "@packages/notifications": ["src/index.ts"],
      "@packages/contracts": ["../../foundation/contracts/src/index.ts"],
      "@packages/infrastructure": ["../../foundation/infrastructure/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "jest.config.js"],
  "exclude": ["dist", "node_modules"]
}
