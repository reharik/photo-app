{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": ".",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "noEmit": false,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "strict": true,
    "isolatedModules": true
  },
  "include": ["src/**/*", "types/**/*.d.ts"],
  "exclude": ["dist", "node_modules", "src/**/*.test.ts", "jest.config.js", "eslint.config.js", "eslint.test.config.js"]
}
