{
  "name": "@packages/heic-converter",
  "version": "0.1.0",
  "description": "Standalone HEIC to JPEG conversion module for Node.js and AWS Lambda",
  "private": true,
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    },
    "./converter": "./src/converter.js",
    "./errors": "./src/errors.js",
    "./lambdaHandler": "./src/lambdaHandler.js"
  },
  "bin": {
    "heic-converter": "./src/cli.js"
  },
  "scripts": {
    "build": "node --eval \"import('./src/index.js')\"",
    "convert": "node ./src/cli.js",
    "lint": "npx eslint --config ../../../../eslint.config.js \"src/**/*.js\" \"test/**/*.js\"",
    "test": "node --test",
    "test:watch": "node --test --watch"
  },
  "keywords": [
    "heic",
    "jpeg",
    "lambda",
    "image-conversion"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "3.1043.0",
    "exifr": "7.1.3",
    "heic-convert": "2.1.0",
    "jpeg-js": "0.4.4",
    "pino": "10.3.1"
  }
}
