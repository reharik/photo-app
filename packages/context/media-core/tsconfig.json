{
  "extends": "../../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "noEmit": false,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "strict": true,
    "paths": {
      "@packages/contracts": ["packages/foundation/contracts/dist/src/index.d.ts"],
      "@packages/infrastructure": ["packages/foundation/infrastructure/src/index.ts"]
    }
  },
  "references": [{ "path": "../../foundation/contracts" }],
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules", "src/tests/**"]
}
