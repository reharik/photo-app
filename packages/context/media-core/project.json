{
  "name": "media-core",
  "projectType": "library",
  "sourceRoot": "{projectRoot}/src",
  "targets": {
    "clean": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "npx rimraf dist"
      }
    },
    "barrels": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{projectRoot}/barrelsby.json",
        "{projectRoot}/src/application/**/*.ts",
        "!{projectRoot}/src/application/index.ts",
        "{projectRoot}/src/repositories/**/*.ts",
        "!{projectRoot}/src/repositories/index.ts",
        "{projectRoot}/src/services/**/*.ts",
        "!{projectRoot}/src/services/index.ts",
        "{projectRoot}/src/domain/**/*.ts",
        "!{projectRoot}/src/domain/index.ts",
        "{projectRoot}/src/types/**/*.ts",
        "!{projectRoot}/src/types/index.ts"
      ],
      "outputs": [
        "{projectRoot}/src/application/index.ts",
        "{projectRoot}/src/repositories/index.ts",
        "{projectRoot}/src/services/index.ts",
        "{projectRoot}/src/domain/index.ts",
        "{projectRoot}/src/types/index.ts"
      ],
      "options": {
        "cwd": "{projectRoot}",
        "command": "npx barrelsby --config barrelsby.json"
      }
    },
    "gen-ioc": {
      "executor": "nx:run-commands",
      "cache": true,
      "dependsOn": ["^build"],
      "inputs": [
        "{projectRoot}/src/ioc.config.ts",
        "{projectRoot}/src/**/*.ts",
        "!{projectRoot}/src/**/*.spec.ts",
        "!{projectRoot}/src/**/*.test.ts",
        "!{projectRoot}/src/**/*.tests.ts",
        "!{projectRoot}/src/**/tests/**",
        "!{projectRoot}/src/generated/**"
      ],
      "outputs": [
        "{projectRoot}/src/generated/ioc-manifest.ts",
        "{projectRoot}/src/generated/ioc-registry.types.ts"
      ],
      "options": {
        "command": "ioc generate",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "@nx/js:tsc",
      "dependsOn": ["barrels", "gen-ioc", "^build"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "outputPath": "{projectRoot}/dist",
        "tsConfig": "{projectRoot}/tsconfig.json",
        "main": "{projectRoot}/src/index.ts"
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "tsc -w -p tsconfig.json"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx eslint --config {projectRoot}/eslint.config.js \"{projectRoot}/**/*.{ts,tsx,js,jsx}\"",
          "npx eslint --config {projectRoot}/eslint.test.config.js --quiet --no-error-on-unmatched-pattern \"{projectRoot}/**/*.tests.ts\" \"{projectRoot}/**/*.tests.tsx\" \"{projectRoot}/**/*.test.ts\" \"{projectRoot}/**/*.test.tsx\" \"{projectRoot}/**/*.spec.ts\" \"{projectRoot}/**/*.spec.tsx\" \"{projectRoot}/src/tests/**/*.ts\" \"{projectRoot}/src/tests/**/*.tsx\""
        ],
        "parallel": false
      },
      "configurations": {
        "fix": {
          "commands": [
            "npx eslint --config {projectRoot}/eslint.config.js --fix \"{projectRoot}/**/*.{ts,tsx,js,jsx}\"",
            "npx eslint --config {projectRoot}/eslint.test.config.js --quiet --fix --no-error-on-unmatched-pattern \"{projectRoot}/**/*.tests.ts\" \"{projectRoot}/**/*.tests.tsx\" \"{projectRoot}/**/*.test.ts\" \"{projectRoot}/**/*.test.tsx\" \"{projectRoot}/**/*.spec.ts\" \"{projectRoot}/**/*.spec.tsx\" \"{projectRoot}/src/tests/**/*.ts\" \"{projectRoot}/src/tests/**/*.tsx\""
          ],
          "parallel": false
        }
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "{projectRoot}",
        "command": "NODE_OPTIONS='--experimental-vm-modules' npx jest --config jest.config.js --runInBand"
      }
    },
    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write {projectRoot}/src/**/*.{ts,tsx,js,jsx,json}"
      }
    }
  },
  "tags": ["layer:context", "scope:media"]
}
