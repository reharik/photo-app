node_modules
.env
.env.local
.env.production
.history
.vscode
dist


.nx/cache
.nx/workspace-data
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md
vite.config.*.timestamp*
vitest.config.*.timestamp*

# API GraphQL: *.generated.* (e.g. types.generated.ts) is local/build output, not committed
*.generated.*

# IoC (regenerated by api / worker builds; do not commit)
apps/api/src/di/generated/**
apps/media-worker/src/di/generated/**

# GraphQL under generated/: list ignored paths only — do NOT use blanket **/generated/ (Git
# will not re-include files when the parent directory is ignored).
apps/api/src/graphql/generated/*
!apps/api/src/graphql/generated/schema.graphql

apps/web/src/graphql/generated/*

# Private keys and certificates
*.pem
*.key
*.p12
*.pfx

# Deployment artifacts
*.tar.gz
backups/

# Docker volumes (if running locally)
pgdata/
caddy_data/
caddy_config/

# Optional loose schema file at repo root (API schema is tracked at apps/api/.../schema.graphql)
/schema.graphql
